# ─────────────────────────────────────────────────────────────
# NewsSense AI — Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# HuggingFace API Token
# Get yours free at: https://huggingface.co/settings/tokens
# Required scope: "Read access to contents of all public gated repos you can access"
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: Rate-limit requests per IP per minute (default: 10)
RATE_LIMIT_RPM=10
